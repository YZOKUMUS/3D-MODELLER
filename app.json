{
  "expo": {
    "name": "YZOKUMUS",
    "slug": "model-market",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "modelmarket",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#064e3b"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#064e3b"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "name": "YZOKUMUS",
      "shortName": "YZOKUMUS",
      "lang": "tr",
      "themeColor": "#0d9488",
      "backgroundColor": "#064e3b",
      "display": "standalone",
      "description": "YZOKUMUS — 3D baskı vitrin"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Model fotograflarini vitrine eklemek icin galeriye ihtiyac var.",
          "cameraPermission": "Kapak fotografi cekmek icin kameraya ihtiyac var."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "baseUrl": "/3D-MODELLER/"
    }
  }
}
