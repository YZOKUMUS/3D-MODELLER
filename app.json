{
  "expo": {
    "name": "YZOKUMUS",
    "slug": "model-market",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "modelmarket",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#064e3b"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#064e3b"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.yzokumus.modelmarket"
    },
    "updates": {
      "url": "https://u.expo.dev/2759da18-e781-4f08-980b-71c2f7787840"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "name": "YZOKUMUS",
      "shortName": "YZOKUMUS",
      "lang": "tr",
      "themeColor": "#0d9488",
      "backgroundColor": "#064e3b",
      "display": "standalone",
      "description": "YZOKUMUS — 3D baskı vitrin"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Model fotograflarini vitrine eklemek icin galeriye ihtiyac var.",
          "cameraPermission": "Kapak fotografi cekmek icin kameraya ihtiyac var."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2759da18-e781-4f08-980b-71c2f7787840"
      }
    }
  }
}
